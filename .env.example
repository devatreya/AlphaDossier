# =============================================================================
# Backend env (.env at repo root)
#
# This file is read by the FastAPI service in services/api/.
# The Next.js frontend has its OWN env file at apps/web/.env.local.
# See apps/web/.env.local.example for the matching frontend variables.
#
# When you fill values in here, mirror SUPABASE_URL / SUPABASE_ANON_KEY into
# apps/web/.env.local under their NEXT_PUBLIC_* names. Next.js requires the
# NEXT_PUBLIC_ prefix to expose vars to client-side code.
# =============================================================================

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Supabase / Postgres
# Mirror SUPABASE_URL  -> NEXT_PUBLIC_SUPABASE_URL  in apps/web/.env.local
# Mirror SUPABASE_ANON_KEY -> NEXT_PUBLIC_SUPABASE_ANON_KEY in apps/web/.env.local
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_SYNTHESIS_MODEL=claude-opus-4-7
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Embeddings
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-finance-2

# Optional embedding fallback
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Data APIs you already have
NEWS_API_KEY=
FRED_API_KEY=

# Optional data APIs
FMP_API_KEY=
COMPANIES_HOUSE_API_KEY=

# SEC identity (required by SEC EDGAR fair-access policy)
SEC_USER_AGENT=AI-quant research prototype contact@example.com

# CORS — comma-separated origins allowed to hit the API.
CORS_ORIGINS=http://localhost:3000

# Feature flags
ENABLE_LIVE_NEWS=true
ENABLE_LIVE_MACRO=true
ENABLE_LIVE_SEC=true
ENABLE_LIVE_UK_DISCLOSURES=true
ENABLE_COMPANIES_HOUSE=false
ENABLE_FMP_TRANSCRIPTS=false
ENABLE_DEMO_MODE=true
