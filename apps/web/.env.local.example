# Frontend env (apps/web/.env.local)
#
# Next.js requires the NEXT_PUBLIC_ prefix on any variable that should be
# readable from client-side code. These mirror values from the backend .env at
# the repo root:
#
#   SUPABASE_URL              -> NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_ANON_KEY         -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   API_BASE_URL              -> NEXT_PUBLIC_API_BASE_URL
#
# Do NOT put SUPABASE_SERVICE_ROLE_KEY here — it must stay server-side only.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
